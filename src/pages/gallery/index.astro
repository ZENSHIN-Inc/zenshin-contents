---
/**
 * ギャラリー一覧ページ
 * scripts/build-slides.ts が src/data/gallery.json に書き出したグループ情報を表示する。
 * 画像本体は public/gallery/ 経由で /gallery/<group>/<file> に配信される
 */
import PageLayout from "@/layouts/PageLayout.astro";
import galleryGroups from "@/data/gallery.json";

interface GalleryGroup {
  group: string;
  files: string[];
}

const groups = galleryGroups as GalleryGroup[];
---

<PageLayout
  title="ギャラリー | ZENSHIN Tech"
  description="株式会社ZENSHINが制作した CG・生成画像などのギャラリー。"
  pageTitle="ギャラリー"
  headerMaxWidth="max-w-6xl"
>
  <section class="bg-surface section-padding">
    <div class="mx-auto max-w-6xl px-6 lg:px-8">
      {
        groups.length > 0 ? (
          groups.map(({ group, files }) => (
            <section class="mb-12 last:mb-0">
              <h2 class="mb-5 border-l-4 border-label pl-3 text-lg font-bold text-primary">{group}</h2>
              <ul class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
                {files.map((file) => (
                  <li>
                    <a
                      href={`/gallery/${group}/${file}`}
                      target="_blank"
                      rel="noopener"
                      class="block overflow-hidden rounded-lg border border-border bg-white transition-transform hover:scale-[1.02] active:scale-95"
                    >
                      <img
                        src={`/gallery/${group}/${file}`}
                        alt={file}
                        loading="lazy"
                        decoding="async"
                        class="aspect-4/3 w-full object-cover"
                      />
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          ))
        ) : (
          <div class="text-center">
            <p class="text-lg text-muted">画像はまだありません。</p>
          </div>
        )
      }
    </div>
  </section>
</PageLayout>
