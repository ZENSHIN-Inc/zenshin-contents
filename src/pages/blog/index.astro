---
/**
 * ブログ一覧ページ（記事のみ。スライドを含む全コンテンツはトップページに表示）
 * 右サイドに BlogSidebar（タグ・月別アーカイブ）を配置
 */
import PageLayout from "@/layouts/PageLayout.astro";
import ArticleCard from "@/components/ArticleCard.astro";
import BlogSidebar from "@/components/BlogSidebar.astro";
import { getCollection } from "astro:content";
import { ROUTES } from "@/consts/routes";
import { filterPublished } from "@/lib/drafts";

const posts = filterPublished(await getCollection("blog")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---

<PageLayout
  title="ブログ | ZENSHIN Tech"
  description="株式会社ZENSHINの技術ブログ。AI駆動開発の技術情報やプロジェクト事例など、さまざまな情報を発信しています。"
  pageTitle="ブログ"
  headerMaxWidth="max-w-6xl"
>
  <section class="bg-surface section-padding">
    <div class="mx-auto max-w-6xl px-6 lg:px-8">
      <div class="lg:grid lg:grid-cols-[minmax(0,1fr)_240px] lg:gap-10 xl:grid-cols-[minmax(0,1fr)_260px]">
        {/* 記事のグリッド */}
        <div class="min-w-0">
          {
            posts.length > 0 ? (
              <ul class="grid grid-cols-1 gap-x-8 gap-y-12 sm:grid-cols-2">
                {posts.map((post, i) => (
                  <ArticleCard
                    href={ROUTES.blogPost(post.data.slug)}
                    ogImageSrc={ROUTES.ogImageBlog(post.data.slug)}
                    title={post.data.title}
                    tags={post.data.tags}
                    date={post.data.date}
                    linkable
                    delay={String(Math.min(i + 1, 5))}
                    isDraft={!post.data.published}
                  />
                ))}
              </ul>
            ) : (
              <div class="text-center">
                <p class="text-lg text-muted">記事はまだありません。</p>
              </div>
            )
          }
        </div>

        {/* サイドバー */}
        <aside class="mt-12 lg:mt-0" aria-label="ブログナビゲーション">
          <BlogSidebar class="lg:sticky lg:top-24" />
        </aside>
      </div>
    </div>
  </section>
</PageLayout>
