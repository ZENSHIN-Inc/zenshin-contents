---
/**
 * ブログ 月別アーカイブページ
 *
 * `/blog/archive/[YYYY-MM]/` の URL で、その月に公開された記事を一覧表示する。
 * ビルド時に `getStaticPaths` で全月分の静的ページを生成する。
 */
import PageLayout from "@/layouts/PageLayout.astro";
import ArticleCard from "@/components/ArticleCard.astro";
import BlogSidebar from "@/components/BlogSidebar.astro";
import { getCollection } from "astro:content";
import { ROUTES } from "@/consts/routes";
import { filterPublished } from "@/lib/drafts";

export async function getStaticPaths() {
  const allPosts = filterPublished(await getCollection("blog"));
  const bucket = new Map<string, typeof allPosts>();
  for (const post of allPosts) {
    const d = post.data.date;
    const ym = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, "0")}`;
    const arr = bucket.get(ym) ?? [];
    arr.push(post);
    bucket.set(ym, arr);
  }
  return [...bucket.entries()].map(([yearMonth, posts]) => ({
    params: { yearMonth },
    props: {
      yearMonth,
      posts: posts.sort(
        (a, b) =>
          new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
      ),
    },
  }));
}

const { yearMonth, posts } = Astro.props;
const [year, month] = yearMonth.split("-");
const label = `${year}年${Number(month)}月`;
---

<PageLayout
  title={`${label}の記事 | ZENSHIN Tech`}
  description={`${label}に公開された技術ブログ記事一覧。株式会社ZENSHINの技術メディア ZENSHIN Tech。`}
  pageTitle={label}
  headerMaxWidth="max-w-6xl"
  breadcrumbs={[
    { name: "ホーム", path: ROUTES.home },
    { name: "ブログ", path: ROUTES.blog },
    { name: label, path: ROUTES.blogArchive(yearMonth) },
  ]}
>
  {/* ヘッダー帯の h1 直下に件数を小さく表示（記事詳細の日付表記と同じトーン） */}
  <p slot="pageMeta" class="mt-3 text-sm text-on-surface-dark/75">
    <span class="font-bold tabular-nums text-on-surface-dark">{posts.length}</span> 件の記事
  </p>

  <section class="bg-surface section-padding">
    <div class="mx-auto max-w-6xl px-6 lg:px-8">
      <div
        class="lg:grid lg:grid-cols-[minmax(0,1fr)_240px] lg:gap-10 xl:grid-cols-[minmax(0,1fr)_260px]"
      >
        <div class="min-w-0">
          {
            posts.length > 0 ? (
              <ul class="grid grid-cols-1 gap-x-8 gap-y-12 sm:grid-cols-2">
                {posts.map((post, i) => (
                  <ArticleCard
                    href={ROUTES.blogPost(post.data.slug)}
                    ogImageSrc={ROUTES.ogImageBlog(post.data.slug)}
                    title={post.data.title}
                    tags={post.data.tags}
                    date={post.data.date}
                    linkable
                    delay={String(Math.min(i + 1, 5))}
                    isDraft={!post.data.published}
                  />
                ))}
              </ul>
            ) : (
              <div class="text-center">
                <p class="text-lg text-muted">該当する記事がありません。</p>
              </div>
            )
          }
        </div>

        <aside class="mt-12 lg:mt-0" aria-label="ブログナビゲーション">
          <BlogSidebar currentYearMonth={yearMonth} class="lg:sticky lg:top-24" />
        </aside>
      </div>
    </div>
  </section>
</PageLayout>
