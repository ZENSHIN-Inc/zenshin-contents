---
/**
 * フッター（ZENSHIN 技術ブログ）— ダーク背景、ロゴ + カテゴリ別サイトマップ + コピーライト
 *
 * 【同期ポリシー】コーポレートサイト zenshin-hp のフッターと同じ見た目を保つ:
 * https://github.com/ZENSHIN-Inc/zenshin-hp/blob/main/src/components/Footer.astro
 * リンク構成や見た目を変更するときは必ず上記ファイルと突き合わせること。
 * 片方だけ修正した場合は、もう片方のリポジトリに同期 Issue を立てるか、その場で修正 PR を出す。
 *
 * zenshin-hp との意図的な差分:
 * - リンク先: 「技術ブログ」だけが当サイト内（/）で、他はコーポレートサイトへの絶対 URL
 * - 当サイトにのみ「購読する」列（RSS・運用者 X）を追加（4列目）
 */
import { Icon } from "astro-icon/components";
import { ROUTES } from "@/consts/routes";

type FooterLink = {
  label: string;
  href: string;
  /** 第三者ドメインへのリンク（アイコンで示し、新規タブで開く） */
  external?: boolean;
};

const linkGroups: { heading: string; links: FooterLink[] }[] = [
  {
    heading: "サービス",
    links: [
      { label: "AI相談サービス", href: ROUTES.corporateAiConsultation },
      {
        label: "業務変革コンサルティング",
        href: ROUTES.corporateBusinessTransformationConsulting,
      },
      { label: "事業内容", href: ROUTES.corporateServices },
      { label: "事例紹介", href: ROUTES.corporateWorks },
    ],
  },
  {
    heading: "企業情報",
    links: [
      { label: "会社情報", href: ROUTES.corporateCompany },
      { label: "ニュース", href: ROUTES.corporateNews },
      { label: "技術ブログ", href: ROUTES.home },
      { label: "採用情報", href: ROUTES.corporateRecruit },
    ],
  },
  {
    heading: "お問い合わせ",
    links: [
      { label: "お問い合わせ", href: ROUTES.corporateContact },
      { label: "プライバシーポリシー", href: ROUTES.corporatePrivacy },
    ],
  },
  {
    heading: "購読する",
    links: [
      { label: "RSS", href: ROUTES.rss },
      { label: "運用者 高橋 俊のX", href: ROUTES.operatorX, external: true },
    ],
  },
];
---

<footer class="bg-surface-dark">
  <div class="mx-auto max-w-6xl px-6 py-12 lg:px-8">
    {/* モバイル: リンク2列が先、ロゴ+住所は最後（参照情報なので下）。lg以上: ロゴ左の5カラム */}
    <div class="grid grid-cols-2 gap-x-6 gap-y-8 lg:grid-cols-[1.5fr_1fr_1fr_1fr_1fr] lg:gap-8">
      <!-- ロゴ + 説明 -->
      <div class="order-last col-span-2 max-w-xs lg:order-none lg:col-span-1">
        <a href={ROUTES.home} class="inline-block active:opacity-70 active:scale-95">
          <img src="/assets/brand/ZENSHIN-logo-white.webp" alt="ZENSHIN - ホームに戻る" width="120" height="28" class="h-6 w-auto" loading="lazy" />
        </a>
        <p class="mt-4 whitespace-nowrap text-sm leading-relaxed text-white/80">
          大手の品質を、AIの速度で。
        </p>
        <address class="mt-3 text-xs not-italic leading-relaxed text-white/60">
          〒150-0041<br />
          東京都渋谷区神南1-11-4<br />
          FPGリンクス神南 5F
        </address>
      </div>

      <!-- カテゴリ別リンク -->
      {linkGroups.map((group) => (
        <nav aria-label={group.heading}>
          <p class="text-xs font-bold tracking-wider text-white/45">{group.heading}</p>
          <ul class="mt-3 space-y-2.5 md:mt-4 md:space-y-3">
            {group.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  target={link.external ? "_blank" : undefined}
                  rel={link.external ? "noopener noreferrer" : undefined}
                  class="text-sm text-white/80 transition-colors hover:text-white active:opacity-70 active:scale-95"
                >
                  {link.label}
                  {link.external && (
                    <Icon name="heroicons:arrow-top-right-on-square-20-solid" class="ml-0.5 inline h-3 w-3 align-[-1px] opacity-60" aria-hidden="true" />
                  )}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      ))}
    </div>
  </div>

  <!-- コピーライト -->
  <div class="border-t border-white/5 py-6">
    <p class="text-center text-sm text-white/80">
      &copy; {new Date().getFullYear()} 株式会社ZENSHIN. All rights reserved.
    </p>
  </div>
</footer>
