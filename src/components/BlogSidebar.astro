---
/**
 * ブログサイドバー
 *
 * 構成:
 *   タグ  — 件数降順、同数なら日本語ロケールでソート
 *   月別アーカイブ — 新しい月順
 *
 * 一覧ページ（/blog/, /blog/tags/[tag]/, /blog/archive/[YYYY-MM]/）では
 * 右サイドに sticky で配置し、ブログ詳細（/blog/[slug]/）では
 * 目次（TOC）の下に並べて 1 つの sticky コンテナに収める。
 *
 * ブログ詳細では TOC と同じ「.blog-card」スタイル（白カード + 柔らかいシャドウ）に揃え、
 * 一覧ページとの視覚的統一感を保つ。
 *
 * データは Props で受け取らず、コンポーネント内で getCollection("blog") を呼ぶ。
 * Astro のコンテンツコレクションはビルド時に 1 回ロードされるためオーバーヘッドは無視できる。
 */
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import { ROUTES } from "@/consts/routes";
import { filterPublished } from "@/lib/drafts";

interface Props {
  /** 現在開いているタグ（ハイライト用）。タグ別一覧ページで指定 */
  currentTag?: string;
  /** 現在開いている月（"YYYY-MM" 形式、ハイライト用）。月別アーカイブページで指定 */
  currentYearMonth?: string;
  /** 外枠に追加するクラス（親側で sticky や余白を調整） */
  class?: string;
}

const {
  currentTag,
  currentYearMonth,
  class: className = "",
} = Astro.props;

const allPosts = filterPublished(await getCollection("blog"));

// タグ集計（件数降順、同数なら日本語ロケール順）
const tagCounts = new Map<string, number>();
for (const post of allPosts) {
  for (const tag of post.data.tags) {
    tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
  }
}
const tags = [...tagCounts.entries()]
  .sort(
    ([a, ca], [b, cb]) => cb - ca || a.localeCompare(b, "ja")
  )
  .map(([tag, count]) => ({ tag, count }));

// 月別集計（新しい月順）
const monthCounts = new Map<string, number>();
for (const post of allPosts) {
  const d = post.data.date;
  const ym = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, "0")}`;
  monthCounts.set(ym, (monthCounts.get(ym) ?? 0) + 1);
}
const months = [...monthCounts.entries()]
  .sort(([a], [b]) => b.localeCompare(a))
  .map(([yearMonth, count]) => {
    const [y, m] = yearMonth.split("-");
    return {
      yearMonth,
      label: `${y}年${Number(m)}月`,
      count,
    };
  });
---

<div class:list={["space-y-5", className]}>
  {/* タグ */}
  <nav aria-label="タグ一覧" class="blog-card rounded-2xl px-5 py-5">
    <h2 class="mb-3 text-sm font-bold tracking-wide text-primary">タグ</h2>
    {tags.length > 0 ? (
      <ul class="flex flex-wrap gap-1.5">
        {tags.map(({ tag, count }) => {
          const isActive = currentTag === tag;
          return (
            <li>
              <a
                href={ROUTES.blogTag(tag)}
                aria-current={isActive ? "page" : undefined}
                class:list={[
                  "inline-flex items-center gap-1 rounded-sm px-2 py-0.5 text-xs font-bold transition-[background-color,transform,opacity] active:scale-95 active:opacity-80",
                  isActive
                    ? "bg-label text-white"
                    : "bg-label/10 text-label hover:bg-label/20",
                ]}
              >
                <span class="inline-flex items-center gap-0.5">
                  <Icon name="heroicons:hashtag-20-solid" class="h-3 w-3 opacity-70" />{tag}
                </span>
                <span class="tabular-nums">({count})</span>
              </a>
            </li>
          );
        })}
      </ul>
    ) : (
      <p class="text-sm text-muted-light">タグはまだありません。</p>
    )}
  </nav>

  {/* 月別アーカイブ — タグと同じピル形式で flex-wrap。間延び防止 + 縦積み時の高さ違和感を軽減 */}
  <nav aria-label="月別アーカイブ" class="blog-card rounded-2xl px-5 py-5">
    <h2 class="mb-3 text-sm font-bold tracking-wide text-primary">月別アーカイブ</h2>
    {months.length > 0 ? (
      <ul class="flex flex-wrap gap-1.5">
        {months.map(({ yearMonth, label, count }) => {
          const isActive = currentYearMonth === yearMonth;
          return (
            <li>
              <a
                href={ROUTES.blogArchive(yearMonth)}
                aria-current={isActive ? "page" : undefined}
                class:list={[
                  "inline-flex items-center gap-1 rounded-sm px-2 py-0.5 text-xs font-bold transition-[background-color,transform,opacity] active:scale-95 active:opacity-80",
                  isActive
                    ? "bg-label text-white"
                    : "bg-label/10 text-label hover:bg-label/20",
                ]}
              >
                <span class="inline-flex items-center gap-0.5 tabular-nums">
                  <Icon name="heroicons:calendar-20-solid" class="h-3 w-3 opacity-70" />{label}
                </span>
                <span class="tabular-nums">({count})</span>
              </a>
            </li>
          );
        })}
      </ul>
    ) : (
      <p class="text-sm text-muted-light">記事はまだありません。</p>
    )}
  </nav>
</div>
